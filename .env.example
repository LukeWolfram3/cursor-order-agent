# Shopify Admin API (read-only recommended for POC; writes are mocked in code)
SHOPIFY_KEY=
SHOPIFY_STORE_DOMAIN=64f9fb-2.myshopify.com
SHOPIFY_API_VERSION=2026-01
# Alias supported by client.ts
# SHOPIFY_ADMIN_ACCESS_TOKEN=

# Anthropic API — used by classifier, order specialist, extractor, location matcher sub-agents
ANTHROPIC_API_KEY=

# HTTP webhook server (pnpm webhook) — Bearer token for POST /webhook or POST /run
WEBHOOK_SECRET=
# Alias supported by src/http/auth.ts
# WEBHOOK_API_KEY=

# Optional HTTP listen port (default 8787)
# PORT=8787

# Optional model overrides (defaults to claude-sonnet-4-6)
# CLASSIFIER_MODEL=claude-sonnet-4-6
# ORDER_SPECIALIST_MODEL=claude-sonnet-4-6
# EXTRACTOR_MODEL=claude-sonnet-4-6
# LOCATION_MATCHER_MODEL=claude-sonnet-4-6
